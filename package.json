{
    "name": "jigsaw",
    "version": "1.0.0",
    "description": "",
    "main": "/src/server.ts",
    "scripts": {
        "dev": "nodemon",
        "migrate": "ts-node src/scripts/migrate.ts up",
        "migrate:revert": "ts-node src/scripts/migrate.ts down",
        "migrate:status": "ts-node src/scripts/migrate.ts status",
        "migrate:generate": "ts-node src/scripts/migrate.ts generate",
        "start:db": "docker compose -f docker-compose.dev.yml up -d --wait",
        "start": "npm run start:db && npm run migrate && npm run dev",
        "test": "vitest",
        "test:run": "vitest run",
        "test:cov": "vitest run --coverage",
        "test:itest": "vitest run tests/integration --pool=threads --maxWorkers=1",
        "test-migrate": "cross-env NODE_ENV=test ts-node src/scripts/migrate.ts up",
        "start:test-db": "docker compose -f docker-compose.test.yml up -d --wait && npm run test-migrate"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.3",
        "@types/express-ejs-layouts": "^2.5.4",
        "@types/node": "^24.0.14",
        "@types/nodemailer": "^7.0.3",
        "@types/pg": "^8.15.5",
        "@vitest/coverage-v8": "^4.0.16",
        "cross-env": "^10.1.0",
        "nodemon": "^3.1.10",
        "prettier-plugin-ejs": "^1.0.3",
        "prettier-plugin-sql": "^0.19.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "vitest": "^4.0.16"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.2.0",
        "ejs": "^3.1.10",
        "express": "^5.1.0",
        "express-ejs-layouts": "^2.5.1",
        "nodemailer": "^7.0.10",
        "pg": "^8.16.3",
        "prettier": "^3.6.2",
        "zod": "^4.1.5"
    }
}
